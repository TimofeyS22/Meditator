# Database
DB_PASSWORD=your_secure_db_password_here

# JWT — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=your_long_random_secret_key_here

# AI Companion via proxyapi.ru (recommended for RU)
AI_BASE_URL=https://api.proxyapi.ru/openai/v1
AI_API_KEY=your_proxyapi_key_here
AI_MODEL=gpt-4o

# Direct OpenAI (fallback, optional)
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...

# CORS — comma separated origins, or * for dev
CORS_ORIGINS=*
